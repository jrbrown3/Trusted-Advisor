# ── Application ──────────────────────────────────────────────
# Generate a strong key (>= 32 bytes) before first run:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=replace-with-a-64-char-random-string-from-secrets-token-urlsafe-48
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# ── Database ──────────────────────────────────────────────────
# SQLite for local dev. Swap to postgres:// for production.
DATABASE_URL=sqlite+aiosqlite:///./trusted_advisor.db

# ── Auth ──────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480    # 8-hour sessions

# ── AI Provider ───────────────────────────────────────────────
# Options: "claude" | "openai"
LLM_PROVIDER=claude
LLM_MODEL_CLAUDE=claude-sonnet-4-6
LLM_MODEL_OPENAI=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
